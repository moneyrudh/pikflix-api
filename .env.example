# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key for Claude-powered recommendations
ANTHROPIC_API_KEY=your-anthropic-api-key

# TMDB Read Access Token (v4 auth) — get one at https://www.themoviedb.org/settings/api
TMDB_READ_ACCESS_TOKEN=your-tmdb-read-access-token

# Supabase project URL and service-role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ── Optional ─────────────────────────────────────────────────────────────────
# API key to protect endpoints. When unset, endpoints are open (dev mode).
# In production, set this and pass it via the X-API-Key header.
# PIKFLIX_API_KEY=your-secret-api-key

# Comma-separated list of allowed CORS origins. Defaults to "*" (dev mode).
# ALLOWED_ORIGINS=https://pikflix.app,https://www.pikflix.app
